{
  "name": "tradeos-public-intel-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source clients, MCP tools, and BYOK examples for TradeOS public intelligence.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/sdk-js",
    "packages/action-intent",
    "packages/cockpit-core",
    "packages/policy-core",
    "packages/tradeos-connectors",
    "packages/mcp-server",
    "modules/feasibility",
    "modules/ea-risk",
    "modules/execution-gateway",
    "modules/ops-dashboard",
    "modules/notification-router",
    "apps/tradeos-agent-cli",
    "apps/market-briefing-bot",
    "apps/symbol-cockpit"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "mcp": "npm --workspace @tradeos/public-intel-mcp-server run dev",
    "cli": "npm --workspace @tradeos/public-intel-agent-cli run dev --",
    "briefing-bot": "npm --workspace @tradeos/market-briefing-bot run dev --",
    "symbol-cockpit": "npm --workspace @tradeos/symbol-cockpit run dev:api",
    "symbol-cockpit:e2e": "npm --workspace @tradeos/symbol-cockpit run e2e:headless"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
