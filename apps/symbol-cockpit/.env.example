TRADEOS_API_BASE=https://api.tradeos.tech/v1/public-intel
TRADEOS_PUBLIC_INTEL_KEY=

LLM_PROVIDER=venice
OPENAI_BASE_URL=https://api.venice.ai/api/v1
VENICE_API_KEY=
OPENAI_API_KEY=
TRADEOS_AGENT_MODEL=z-ai-glm-5-turbo
TRADEOS_AGENT_TIMEOUT_MS=45000

COCKPIT_BIND_HOST=127.0.0.1
COCKPIT_API_PORT=18100
COCKPIT_WEB_PORT=18101
COCKPIT_DEFAULT_CHAIN=8453
COCKPIT_DEFAULT_MODE=trader
# Default sample keeps local scanner volume low. Full trading-intelligence
# universe:
# BTC,ETH,SOL,ADA,DOGE,XRP,DOT,POL,LINK,UNI,VVV,KTA
# AVAX,NEAR,ARB,OP,SUI,APT,INJ,TIA,FET
COCKPIT_WATCHLIST=VVV,BTC,ETH,SOL
COCKPIT_WORKER_INTERVAL_SECONDS=900
COCKPIT_LOCAL_ACCOUNT_BALANCE_USD=10000
COCKPIT_SUBMIT_FEEDBACK=false

COCKPIT_ALERT_EMAIL_ENABLED=false
COCKPIT_ALERT_EMAIL_TO=tradeos.contact@gmail.com
COCKPIT_ALERT_EMAIL_MIN_SEVERITY=warning
COCKPIT_PUBLIC_BASE_URL=
COCKPIT_FEEDBACK_BASE_URL=https://tradeos.tech/feedback
COCKPIT_SMTP_HOST=
COCKPIT_SMTP_PORT=587
COCKPIT_SMTP_USER=
COCKPIT_SMTP_PASSWORD=
COCKPIT_SMTP_FROM=
COCKPIT_SMTP_STARTTLS=true

POSTGRES_URL=postgres://tradeos:tradeos@postgres:5432/tradeos_cockpit
EXECUTION_MODE=paper
