{
  "name": "@agenticsrclab/tradeos-public-intel-mcp-server",
  "version": "0.1.0",
  "mcpName": "io.github.agenticsrclab/tradeos-public-intel-mcp",
  "description": "MCP server for TradeOS public intelligence.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://tradeos.tech",
  "repository": {
    "type": "git",
    "url": "https://github.com/agenticsrclab/tradeos-public-intel-kit.git",
    "directory": "packages/mcp-server"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tradeos",
    "crypto",
    "market-intelligence",
    "public-intelligence"
  ],
  "bin": {
    "tradeos-public-intel-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:deps && tsc -p tsconfig.json && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:zod",
    "build:deps": "npm --workspace @tradeos/public-intel-sdk run build && npm --workspace @tradeos/cockpit-core run build",
    "dev": "tsx src/index.ts",
    "registry:check": "node scripts/check-registry-metadata.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tradeos/cockpit-core": "0.1.0",
    "@tradeos/public-intel-sdk": "0.1.0",
    "esbuild": "^0.27.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8"
  }
}
