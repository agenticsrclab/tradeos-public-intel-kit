TRADEOS_API_BASE=https://api.tradeos.tech/v1/public-intel
# Optional. Required only for SDK/CLI app-key management. Keep server-side.
TRADEOS_ACCOUNT_TOKEN=
# Optional. Public reads work without this. Use after TradeOS issues an app key
# for attribution. Keep server-side.
TRADEOS_PUBLIC_INTEL_KEY=

LLM_PROVIDER=venice
OPENAI_BASE_URL=https://api.venice.ai/api/v1
# Required only for `tradeos-intel ask` with the default Venice provider.
# Get a Venice key at https://venice.ai/pricing
VENICE_API_KEY=
OPENAI_API_KEY=
TRADEOS_AGENT_MODEL=z-ai-glm-5-turbo
TRADEOS_AGENT_TIMEOUT_MS=45000
TRADEOS_AGENT_DIGEST_LIMIT=5

# Market briefing bot.
TRADEOS_BRIEFING_PLATFORM=stdout
TRADEOS_BRIEFING_CHAIN_ID=8453
TRADEOS_BRIEFING_DIGEST_LIMIT=5
TRADEOS_BRIEFING_WATCHLIST_LIMIT=5
TRADEOS_BRIEFING_USE_LLM=true
TRADEOS_BRIEFING_DRY_RUN=false
TRADEOS_BRIEFING_SUBMIT_FEEDBACK=false
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
